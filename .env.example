# Token de integración interna de Notion (https://www.notion.so/profile/integrations)
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la página padre donde se creará la database (solo necesario para `npm run setup:notion`)
NOTION_PARENT_PAGE=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la database de crónicas (output de `npm run setup:notion`)
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────────────────────
# Rebuild endpoint (Fase 4) — solo en Netlify, no hace falta local
# ────────────────────────────────────────────────────────────

# Token secreto que valida la llamada al endpoint /api/rebuild
# Genera uno con: openssl rand -hex 24
REBUILD_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL del Build Hook de Netlify (Site settings → Build & deploy → Build hooks)
NETLIFY_BUILD_HOOK_URL=https://api.netlify.com/build_hooks/xxxxxxxxxxxxxxxxxxxxxxxx
