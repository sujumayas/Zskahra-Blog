---
import TagBadge from "./TagBadge.astro";
import type { CronicaMeta } from "@/lib/notion-types";

interface Props {
  cronica: CronicaMeta;
}

const { cronica } = Astro.props;

const fechaIRL = cronica.fechaIRL
  ? new Date(cronica.fechaIRL + "T00:00:00").toLocaleDateString("es-ES", {
      day: "numeric",
      month: "long",
      year: "numeric",
    })
  : null;
---

<a
  href={`/cronicas/${cronica.slug}/`}
  class="group block rounded-md border border-ink-500/30 bg-ink-700/20 p-6 transition hover:border-ember-500/60 hover:bg-ink-700/40"
>
  <div class="flex items-baseline justify-between gap-4 font-sans text-xs uppercase tracking-[0.2em] text-ink-300">
    <span>
      {cronica.sessionNumber !== null ? `Sesión ${cronica.sessionNumber}` : "Crónica"}
      {cronica.cronista && (
        <>
          {" · "}
          <span class="text-ember-300">{cronica.cronista}</span>
        </>
      )}
    </span>
    {fechaIRL && <span>{fechaIRL}</span>}
  </div>

  <h2 class="mt-3 font-serif text-2xl font-light text-ink-50 transition group-hover:text-ember-300">
    {cronica.title}
  </h2>

  {cronica.resumenCorto && (
    <p class="mt-2 text-ink-200">{cronica.resumenCorto}</p>
  )}

  {cronica.etiquetas.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {cronica.etiquetas.map((tag) => (
        <TagBadge label={tag} variant="subtle" />
      ))}
    </div>
  )}
</a>
