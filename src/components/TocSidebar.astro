---
import type { Heading } from "@/lib/markdown";

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
---

{headings.length > 0 && (
  <aside class="hidden lg:block">
    <div
      class="sticky top-12 max-h-[calc(100vh-6rem)] overflow-y-auto border-l border-ink-500/30 pl-6"
    >
      <p class="font-sans text-xs uppercase tracking-[0.25em] text-ink-300">
        En esta crónica
      </p>
      <ol class="mt-4 flex flex-col gap-2 font-sans text-sm">
        {headings.map((h) => (
          <li class={h.depth === 3 ? "pl-3" : ""}>
            <a
              href={`#${h.id}`}
              class={`block transition hover:text-ember-300 ${
                h.depth === 2 ? "text-ink-100" : "text-ink-200"
              }`}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </div>
  </aside>
)}
