---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Prose from "@/components/Prose.astro";
import TagBadge from "@/components/TagBadge.astro";
import PrevNextNav from "@/components/PrevNextNav.astro";
import TocSidebar from "@/components/TocSidebar.astro";
import {
  listPublishedCronicas,
  getCronicaBySlug,
  getAdjacentCronicas,
} from "@/lib/notion";

export async function getStaticPaths() {
  const cronicas = await listPublishedCronicas();
  return cronicas.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
if (!slug) throw new Error("Missing slug param");

const cronica = await getCronicaBySlug(slug);
if (!cronica) throw new Error(`Crónica no encontrada: ${slug}`);

const { prev, next } = await getAdjacentCronicas(slug);

const fechaIRL = cronica.fechaIRL
  ? new Date(cronica.fechaIRL + "T00:00:00").toLocaleDateString("es-ES", {
      day: "numeric",
      month: "long",
      year: "numeric",
    })
  : null;
---

<BaseLayout title={`${cronica.title} · Zskahra`} description={cronica.resumenCorto}>
  <div class="mx-auto max-w-6xl px-6 py-12 lg:grid lg:grid-cols-[minmax(0,1fr)_220px] lg:gap-12">
    <div class="min-w-0">
      <a
        href="/"
        class="font-sans text-xs uppercase tracking-[0.2em] text-ink-300 transition hover:text-ember-300"
      >
        ← Todas las crónicas
      </a>

      <article class="mt-6">
        <header class="mb-10 border-b border-ink-500/30 pb-8">
          <p class="font-sans text-sm uppercase tracking-[0.3em] text-ember-500">
            {cronica.sessionNumber !== null ? `Sesión ${cronica.sessionNumber}` : "Crónica"}
          </p>
          <h1 class="mt-3 font-serif text-4xl font-light leading-tight text-ink-50 sm:text-5xl">
            {cronica.title}
          </h1>

          {cronica.resumenCorto && (
            <p class="mt-4 max-w-prose font-serif text-xl italic text-ink-200">
              {cronica.resumenCorto}
            </p>
          )}

          <dl class="mt-6 grid gap-3 font-sans text-sm text-ink-200 sm:grid-cols-2">
            {cronica.cronista && (
              <div>
                <dt class="text-xs uppercase tracking-wider text-ink-300">Cronista</dt>
                <dd class="text-ink-100">{cronica.cronista}</dd>
              </div>
            )}
            {fechaIRL && (
              <div>
                <dt class="text-xs uppercase tracking-wider text-ink-300">Sesión IRL</dt>
                <dd class="text-ink-100">{fechaIRL}</dd>
              </div>
            )}
            {cronica.fechaMundo && (
              <div>
                <dt class="text-xs uppercase tracking-wider text-ink-300">Fecha-mundo</dt>
                <dd class="text-ink-100">{cronica.fechaMundo}</dd>
              </div>
            )}
            {cronica.personajes.length > 0 && (
              <div>
                <dt class="text-xs uppercase tracking-wider text-ink-300">Personajes</dt>
                <dd class="text-ink-100">{cronica.personajes.join(" · ")}</dd>
              </div>
            )}
          </dl>

          {cronica.etiquetas.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-2">
              {cronica.etiquetas.map((tag) => (
                <TagBadge label={tag} />
              ))}
            </div>
          )}
        </header>

        <Prose html={cronica.html} />
      </article>

      <PrevNextNav prev={prev} next={next} />
    </div>

    <TocSidebar headings={cronica.headings} />
  </div>
</BaseLayout>
