---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Zskahra · Crónicas">
  <header class="mb-12">
    <p class="font-sans text-sm uppercase tracking-[0.3em] text-ember-500">
      Bitácora de sesiones
    </p>
    <h1 class="mt-3 font-serif text-5xl font-light text-ink-50">
      Crónicas de Zskahra
    </h1>
    <p class="mt-4 max-w-prose text-ink-200">
      Aquí viven las crónicas escritas por los jugadores tras cada sesión. Aún
      no hay nada publicado — pronto.
    </p>
  </header>

  <section
    class="rounded border border-ink-500/40 bg-ink-700/30 p-6 font-sans text-sm text-ink-200"
  >
    <p class="font-semibold text-ember-300">Estado: bootstrap</p>
    <p class="mt-2">
      Proyecto inicializado con Astro 6 + Tailwind v4 + TypeScript strict. La
      integración con Notion llega en la siguiente fase.
    </p>
  </section>
</BaseLayout>
