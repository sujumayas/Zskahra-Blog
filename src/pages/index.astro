---
import BaseLayout from "../layouts/BaseLayout.astro";
import CronicaCard from "@/components/CronicaCard.astro";
import { listPublishedCronicas } from "@/lib/notion";

const cronicas = await listPublishedCronicas();
---

<BaseLayout title="Zskahra · Crónicas">
  <main class="mx-auto max-w-4xl px-6 py-12">
    <header class="mb-12">
      <p class="font-sans text-sm uppercase tracking-[0.3em] text-ember-500">
        Bitácora de sesiones
      </p>
      <h1 class="mt-3 font-serif text-5xl font-light text-ink-50">
        Crónicas de Zskahra
      </h1>
      <p class="mt-4 max-w-prose text-ink-200">
        Cada entrada es la crónica de una sesión, escrita por uno de los
        jugadores. El cronista rota.
      </p>
    </header>

    {cronicas.length === 0 ? (
      <section
        class="rounded-md border border-ink-500/40 bg-ink-700/30 p-8 font-sans text-ink-200"
      >
        <p class="text-ember-300">Aún no hay crónicas publicadas.</p>
        <p class="mt-2 text-sm">
          Marca una crónica como <code class="text-ember-300">Estado = Publicado</code> en Notion
          y volverá a aparecer aquí en el próximo build.
        </p>
      </section>
    ) : (
      <section class="flex flex-col gap-4">
        {cronicas.map((cronica) => (
          <CronicaCard cronica={cronica} />
        ))}
      </section>
    )}
  </main>
</BaseLayout>
